{
  "name": "react-fusion-state",
  "version": "1.1.1",
  "description": "Simple, fast React state management with zero dependencies, built-in persistence (localStorage / AsyncStorage), TypeScript inference, and a compact bundle.",
  "keywords": [
    "react",
    "react-native",
    "state-management",
    "global-state",
    "hooks",
    "persistence",
    "localstorage",
    "asyncstorage",
    "typescript",
    "zero-dependency",
    "lightweight",
    "fusion-state",
    "redux-alternative",
    "zustand-alternative",
    "recoil-alternative",
    "ssr"
  ],
  "homepage": "https://github.com/jgerard72/react-fusion-state#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=16"
  },
  "author": "Jacques GERARD <jgrd93@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgerard72/react-fusion-state.git"
  },
  "bugs": {
    "url": "https://github.com/jgerard72/react-fusion-state/issues"
  },
  "scripts": {
    "build": "rm -rf dist/* && tsc -p tsconfig-build.json && npm run build:demo",
    "build:demo": "node scripts/build-demo.js",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "npm run build",
    "dev": "tsc -w -p tsconfig-build.json",
    "demo": "npm run build && open demo/demo-persistence.html",
    "benchmark": "node benchmark/final-performance-report.js",
    "benchmark:detailed": "node benchmark/performance-comparison.js",
    "benchmark:bundle": "node benchmark/bundle-size-analysis.js",
    "publish:dry": "npm publish --dry-run",
    "publish:performance": "npm publish && echo '🏆 Published with zero dependencies and benchmark-proven performance!'"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md",
    "PERFORMANCE_BENCHMARK_RESULTS.md"
  ],
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^7.32.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.2.6",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^4.0.0"
  }
}
