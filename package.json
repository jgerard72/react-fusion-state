{
  "name": "react-fusion-state",
  "version": "0.0.67",
  "homepage": "https://github.com/jgerard72/react-fusion-state/master/imags/react-fusion-state.png",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "author": "Jacques GERARD <jgrd93@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jgerard72/react-fusion-state"
  },
  "scripts": {
    "build": "tsup",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest",
    "test:types": "npm run build && tsc --noEmit -p test-types/tsconfig.json",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "dev": "tsc -w -p tsconfig-build.json"
  },
  "keywords": [
    "react",
    "state-management",
    "global-state",
    "react-native"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/lodash.isequal": "^4.5.8",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "eslint": "^7.32.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lodash.isequal": "^4.5.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.2.6",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tsup": "^8.4.0",
    "typescript": "^4.0.0"
  }
}
